m1 --> m1:
m1 -> m1: this.handledThisTick +=1
m1 --> m1
m1 -> m1: setLocation(t40)
m1 --> m1
m1 -> pf: createWheatPlant()
pf -> hw: Window(JUN1, JUL1)
hw --> pf: hw
pf -> bw: Window(MAY1, MAY1)
bw --> pf: bw
pf -> hl: LateRule(20, 2)
hl --> pf: hl
pf -> wr: FieldWeedingRule([3, 9])
wr --> pf: wr
pf -> w: Plant(WHEAT, initialEstimate:1'500'000, moistureRequired:450, sunlightComfort:90, pollination:SELF-POLLINATES, harvestWindow:hw, bloomWindows:bw, harvestLate:hl, sowWindows:sw, weedingRule:wr)
w --> pf: w
pf --> m1: w
m1 -> w : setProgress(SOWING, 32)
w --> m1:
m1 -> t40: setPlant(w)
t40 --> m1
m1 -> l: logFarmAction(1, SOWING, 40, 4)
l --> m1:
