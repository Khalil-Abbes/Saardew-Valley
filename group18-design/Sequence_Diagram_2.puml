tm --> m2:  True
m2 -> m2: this.location = t12
m2 --> m2
m2 -> l: logMachineReturn(2, 12)
l --> m2
m2 --> farm

farm -> farm: getFieldsWithHarvestablePlants(32, 19)
farm --> farm: [t46, t50, t54]
