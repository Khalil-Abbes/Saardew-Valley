farm --> farm: [t42, t46, t50, t54]
farm -> farm: filterAlreadyWorked([t42, t46, t50, t54])
loop for each tile in [t42, t46, t50, t54]
group if Tile has already been worked on this tick [t42]
farm -> t42: getProgress()
t42 --> farm : <Harvesting, 32>
farm -> t42: [t42, t46, t50, t54].remove(42)
end
group if Tile hasn't been already worked on this tick
farm -> t46: getProgress()
t46 --> farm :<>
end
farm --> farm: l = [t46, t50, t54]
end

farm -> m3: canHandle(PUMPKIN, t46)

m3 -> m3: this.handledThisTick * this.duration <= 14
m3 --> m3: True
m3 -> tm: existsPath(t12, t46, 3, false)
tm --> m3: True
m3 --> farm: True
farm -> m3: doIrrigating(t46, 32)
m3 ->m3: setIsAvailable(False)
m3 -->m3
