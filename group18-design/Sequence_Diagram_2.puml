l --> farm:
farm --> s:
 s--> s:

end

group IncidentsHappenPhase

s -> s: incidentStart()
s -> s: getIncidents()
s --> s: []
s --> s:

end


group ComputeHarvestPhase

s -> s: computeHarvest()

s -> tm: getFieldsAndPlantations()
tm --> s: [t40, t42, t43, t44, t46, t48, t50, t52, t54]

loop while Tile list is not empty
s -> t40 : updateHarvestEstimate(32, 19)
t40 -> t40 : isSowed(32)
t40 --> t40 : true
t40 -> t40 : resetHarvestAfterSowed()
t40 --> t40:
t40 -> t40 : getMissedAction()
t40 --> t40 : missedActionList = []
t40 -> t40 : missedActionList.isEmpty()
t40 --> t40 : true
t40 -> t40: applyEnvironmentalPenalty()
t40 --> t40:
t40 -> t40: applyMissedActionPenalty()
t40 --> t40:
t40 -> t40 : applyIncidentEffect()
t40 --> t40 :
t40 -> l : logHarvestEstimateChange(this.id, this.plant.currentEstimate, this.plant)
l --> t40 :
t40 --> s :
end

s --> s: 

end



@enduml