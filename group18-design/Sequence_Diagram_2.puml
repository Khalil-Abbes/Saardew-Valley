l --> m1:
m1 --> farm: True
farm -> sp3: setFulfilled()
sp3 --> farm
farm -> tm: getFieldsAndPlantationsSameFarmInRadius(34, t40, 2)
tm --> farm: [t42, t44]
farm -> farm: [t40, t43, t44, t48, t52].getIntersection([t42, t44])
