t44 --> farm: True
farm -> m1: canHandle(WHEAT, t44)
m1 -> tm : existsPath(t40, t44, 3, False)
tm --> m1: True
m1 --> farm: True
farm -> m1: doSowing(t44, 32, 19, WHEAT)
m1 -> m1: setIsAvailable(False)
m1 --> m1:
m1 -> m1: this.handledThisTick +=1
m1 --> m1
m1 -> m1: setLocation(t44)
m1 --> m1
m1 -> pf: createWheatPlant()
pf --> m1: w2
m1 -> w2 : setProgress(SOWING, 32)
w2 --> m1:
m1 -> t44: setPlant(w2)
t44 --> m1
m1 -> l: logFarmAction(1, SOWING, 44, 4)
l --> m1:
m1 -> l: logFarmSowing(44, WHEAT, 3)
l --> m1:
m1 --> farm: True
farm -> tm: getFieldsAndPlantationsSameFarmInRadius(34, t44, 2)
tm --> farm: [t43, t46, t48]
farm -> farm: [t40, t43, t44, t48, t52].getIntersection([t43, t46, t48])
farm --> farm: [t43, t48]
farm -> t43: canBeSowed(32, 19, WHEAT)
t43 --> farm: False
farm -> t48: canBeSowed(32, 19, WHEAT)
t48 --> farm: False




farm -> m1: returnToFarmstead(machineToShed[m1])
m1 -> tm: existsPath(t44, t12, 3, False)
tm --> m1:  True
m1 -> m1: setLocation(t12)
m1 --> m1
m1 --> farm: True

farm -> l: logMachineReturn(1, 12)
l --> farm
farm --> farm
farm --> farm



farm -> farm: harvestPlantations(32, 19)
farm -> farm: getPlantationsWithHarvestablePlants(32, 19)
farm -> farm: getPlantations()
farm --> farm:
farm --> farm: []
farm --> farm:


farm -> farm: harvestFields(32, 19)
farm -> farm: getFieldsWithHarvestablePlants(32, 19)
farm --> farm: [t42, t46, t50, t54]
farm -> farm: getAvailableHarvestingMachines()
farm --> farm: [m2]
farm -> t42: getPlantType()
t42 --> farm: PUMPKIN

farm -> m2: canHandle(PUMPKIN, t42)
m2 -> tm: existsPath(t12, t42, 3, false)
tm --> m2: True
m2 --> farm: True
farm -> m2: doHarvesting(t42, 32)

m2 -> m2: setIsAvailable(False)
m2 --> m2:
m2 -> m2: this.handledThisTick +=1
m2 --> m2:
m2 -> m2: setLocation(t42)
m2 --> m2:
m2 -> t42: getPlant()
t42 --> m2: p
m2 -> p: getCurrentEstimate()
p --> m2: 320'850
m2 -> m2: setCargo(PUMPKIN, 320'850)
m2 --> m2:
m2 -> p: setProgress(HARVESTING, 32)
p -> p: setCurrentHarvestEstimate(0)
p --> p:
p --> m2

m2 -> l: logFarmAction(2, HARVESTING, 42, 10)
l --> m2
m2 -> l: logFarmHarvest(2, ,PUMPKIN)
l --> farm:

m2 --> farm: True
farm -> tm: getFieldsAndPlantationsSameFarmInRadius(34, t42, 2)
tm --> farm: [t40, t44, t46]
farm -> farm: [t40, t44, t46].filterBy{ PUMPKIN == it.plant.plantType && it.needsHarvesting() }
