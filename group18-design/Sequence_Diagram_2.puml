participant "p: FieldPlant" as p
participant "cloudHandler: CloudHandler" as ch
participant "tileManager: TileManager" as tm
participant "sp3: SowingPlan" as sp3
participant "hw: HarvestWindow" as hw
participant "bw: BloomWindow" as bw
participant "hl: HarvestLate" as hl
participant "wr: WeedingRule" as wr
participant "pf: plantFactory" as pf
participant "t40: Field" as t40
participant "t44: Field" as t44
participant "t42: Field" as t42
participant "t43: Field" as t43
participant "t48: Field" as t48

s -> s: runTick(32, OCT1)
s -> l: logTickStart(32, 19)
l --> s:

group reduceSoilMoisturePhase

s -> s: reduceSoilMoisture()
s -> tm: getFields()
tm --> s: [t40, t42, t43, t44, t46, t48, t50, t52, t54]

loop for each field in fields
    group Tile 43, 44, 48
    s -> f: getPlant()
    f --> s: p
    s -> s: isNull(p)
    s --> s: True
    s -> f: reduceSoilMoisture(70)
    f --> s:
    s -> f: moistureBelowThreshold()
    f --> s: True
    end
    group  Tile 40, 42, 46, 50, 52, 54
    s -> f: getPlant()
    f --> s: p
    s -> s: isNull(p)
    s --> s: False
    s -> f: reduceSoilMoisture(100)
    f --> s:
    s -> f: moistureBelowThreshold()
    f --> s: True
    end

end

s -> l: logSoilMosture(9, 0)
l --> s:
s --> s:

end


group CloudPhase

s -> s: handleClouds()
s -> ch: getClouds()
ch --> s: []
s --> s:

end


group FarmActionPhase

s -> s: farmAction(32, OCT1)
s -> s: getFarms()
s --> s: [f34]
s -> farm: run(32, OCT1)
farm -> l: logFarmStart(34)
l --> farm:
