' ===== Enums =====

package Plant #gray {

' ===== Value objects =====
class Window {
  ' Absolute start tick in year (1..24), see Table 1 (§2.2.1)
  - startTick: YearTick
  ' Absolute end tick in year (1..24), inclusive
  - endTick: YearTick
  - lateRule: LateRule?

  + contains(yearTick: YearTick): Boolean
}


class LateRule {
  ' Percentage penalty per late tick (e.g., 20 for −20%/tick; §2.2.2)
  - perTickPenaltyPct: Int
  ' Number of late ticks that can be penalized before hard stop
  - ticksAllowed: Int
}

class FieldWeedingRule {
  - offsets: List<Int>
  - everyN: Int?
}

' ===== Plant specification =====
abstract class Plant {
  - progress: MutableMap<ActionType, List<Pair<Int, YearTick>>> = mutableMapOf()
  ' Plant identity (one of the 8 plants; §2.2.2)
  - type: PlantType
  ' Base estimate in grams under optimal conditions (per plant; §2.2.2)
  - initialHarvestEstimate: Int
  ' Required soil moisture in L/tick for no penalty (per plant; §2.2.2)
  - moistureRequired: Int
  ' Comfortable sunlight hours per tick; >comfort → −10% per +25h (§2.2.2 “Sunlight”)
  - sunlightComfort: Int
  ' Pollination mode (NONE/SELF/INSECTS; §2.2.2)
  - pollination: Pollination
  - harvestWindow: Window
  - BloomWindows: List<Window>
  + isInBloomWindow(sowingTick: Int, yearTick: YearTick): Boolean
  + isInHarvestWindow(yearTick: YearTick): Boolean
  + setProgress(action: ActionType, tick: Int)
}

class PlantFactory {
  + createPotatoPlant(): FieldPlant
  + createWheatPlant(): FieldPlant
  + createOatPlant(): FieldPlant
  + createPumpkinPlant(): FieldPlant
  + createApplePlant(): PlantationPlant
  + createGrapePlant(): PlantationPlant
  + createAlmondPlant(): PlantationPlant
  + createCherryPlant(): PlantationPlant
}



class FieldPlant {
  - sowWindow: Window
  - weedingRule: FieldWeedingRule?

  + isInSowingWindow(yearTick: YearTick): Boolean
  + isInWeedingWindow(sowingTick: Int, yearTick: YearTick): Boolean

}

class PlantationPlant {
  - cuttingWindow: Window
  - mowingWindows: List<Window>

  + isInCuttingWindow(yearTick: YearTick): Boolean
  + isInMowingWindow(yearTick: YearTick): Boolean
}
}

package enum #purple {
enum TileCategory {
    FARMSTEAD
    VILLAGE
    ROAD
    MEADOW
    FIELD
    PLANTATION
    EMPTY
    FOREST
}
TileCategory --o Tile.Tile

enum Direction {
  ANGLE_0(0)
  ANGLE_45(45)
  ANGLE_90(90)
  ANGLE_135(135)
  ANGLE_180(180)
  ANGLE_225(225)
  ANGLE_270(270)
  ANGLE_315(315)
}
Tile.Tile o-- Direction
Simulation.Coordinate ..> Direction

enum ActionType {
  SOWING,
  CUTTING,
  MOWING,
  WEEDING,
  IRRIGATING,
  HARVESTING
}

enum YearTick {
  JAN1 (tick = 1, sunlight = 98)
  JAN2 (tick = 2, sunlight = 98)
  FEB1 (tick = 3, sunlight = 112)
  FEB2 (tick = 4, sunlight = 112)
  MAR1 (tick = 5, sunlight = 126)
  MAR2 (tick = 6, sunlight = 126)
  APR1 (tick = 7, sunlight = 140)
  APR2 (tick = 8, sunlight = 140)
  MAI1 (tick = 9, sunlight = 168)
  MAI2 (tick = 10, sunlight = 168)
  JUN1 (tick = 11, sunlight = 168)
  JUN2 (tick = 12, sunlight = 168)
  JUL1 (tick = 13, sunlight = 168)
  JUL2 (tick = 14, sunlight = 168)
  AUG1 (tick = 15, sunlight = 154)
  AUG2 (tick = 16, sunlight = 154)
  SEP1 (tick = 17, sunlight = 126)
  SEP2 (tick = 18, sunlight = 126)
  OCT1 (tick = 19, sunlight = 112)
  OCT2 (tick = 20, sunlight = 112)
  NOV1 (tick = 21, sunlight = 98)
  NOV2 (tick = 22, sunlight = 98)
  DEC1 (tick = 23, sunlight = 84)
  DEC2 (tick = 24, sunlight = 84)
}

enum PlantType  {
  POTATO ( Window(APR1, MAI2, null) )
  WHEAT ( Window(OCT1, OCT2, LateRule(20, 2)) )
  OAT ( Window(MAR2, MAR2, LateRule(20, 2)) )
  PUMPKIN ( Window(MAI2, JUN2, null) )
  APPLE (null)
  GRAPE (null)
  ALMOND (null)
  CHERRY (null)
}

enum Pollination {
  ' No insect dependence (or not applicable)
  NONE
  ' Self-pollinating plants (e.g., Wheat, Oat, Grape; §2.2.2)
  SELF
  ' Requires insects during bloom (e.g., Potato, Pumpkin, Apple, Cherry, Almond; §2.2.2)
  INSECTS
}
Plant.Plant o-- Pollination
}


'============ Associations of all classes ============

'Tile
Tile.FarmableTile --|> Tile.Tile
Tile.Plantation -|> Tile.FarmableTile
Tile.Field -|> Tile.FarmableTile

Tile.Tile o--  enum.TileCategory
Tile.Tile o-- enum.Direction

Tile.Field o-- enum.PlantType
Tile.Field o-- Plant.FieldPlant

Tile.Plantation o-- Plant.PlantationPlant

'Cloud
Cloud.CloudHandler o-- Cloud.Cloud
Cloud.CloudHandler o-- Simulation.TileManager

'Farm
Farm.Machine o-- Simulation.TileManager
Farm.Machine o-- enum.ActionType

Farm.Farm o-- Farm.SowingPlan
Farm.Farm o-- Farm.Machine
Farm.Farm o-- Tile.Field
Farm.Farm o-- Tile.Plantation
Farm.Farm o-- Tile.Tile
Farm.Farm o-- enum.PlantType

Farm.SowingPlan o-- enum.PlantType
Farm.SowingPlan o-- Tile.Field

Farm.Machine o-- enum.PlantType
Farm.Machine ..> Plant.PlantFactory


'Incidents
Incidents.Incident <|-- Incidents.CloudCreationIncident
Incidents.Incident <|-- Incidents.BeeHappyIncident
Incidents.Incident <|-- Incidents.DroughtIncident
Incidents.Incident <|-- Incidents.BrokenMachineIncident
Incidents.Incident <|-- CityExpansionIncident
Incidents.Incident <|-- AnimalAttackIncident

Incidents.BeeHappyIncident o-- Simulation.TileManager
Incidents.DroughtIncident o-- Simulation.TileManager
Incidents.CityExpansionIncident o-- Simulation.TileManager
Incidents.AnimalAttackIncident o-- Simulation.TileManager

Incidents.CloudCreationIncident o-- Cloud.CloudHandler
Incidents.BrokenMachineIncident o-- Farm.Farm
Incidents.CityExpansionIncident o-- Farm.Farm

'Simulation
Simulation.Coordinate ..> enum.Direction
Simulation.Main ..> Parser.MainParser
Simulation.Main ..> Simulation.Simulation

Simulation.Simulation o-- enum.YearTick
Simulation.Simulation o-- Incidents.Incident
Simulation.Simulation o-- Farm.Farm
Simulation.Simulation o-- Cloud.CloudHandler
Simulation.Simulation o-- Simulation.TileManager
Simulation.TileManager o-- Tile.Tile
Simulation.TileManager o-- Simulation.Coordinate

'Plant
Plant.FieldPlant --|> Plant.Plant
Plant.PlantationPlant -|> Plant.Plant

Plant.Plant o-- Plant.Window
Plant.Window o-- Plant.LateRule
Plant.FieldPlant o- Plant.FieldWeedingRule

Plant.PlantFactory ..> Plant.FieldPlant
Plant.PlantFactory ..> Plant.PlantationPlant

Plant.Plant o-- enum.ActionType
Plant.Plant o-- enum.PlantType
Plant.Window o-- enum.YearTick
Plant.Plant o-- enum.Pollination

'Logger
Logger.LoggerFacade o-- Logger.ImportantLogger

Logger.InfoLogger -|> Logger.ImportantLogger
Logger.DebugLogger -|> Logger.InfoLogger

'Parser
Parser.MapParser ..> Parser.TileFactory
Parser.TileFactory ..> Tile.Tile

Parser.MapParser <.. Parser.MainParser
Parser.FarmParser <.. Parser.MainParser
Parser.ScenarioParser <.. Parser.MainParser

@enduml