@startuml SAARDEW_VALLEY


package Tile #pink {

class Tile   {
    - id: Int
    - coordinate: Coordinate
    - categoryType: TileCategory
    - shed: Boolean
    - farm: Int?
    - direction: Direction?
}

abstract class FarmableTile {
    - moistureCapacity: Int
    - currentMoisture: Int
    - currentHarvestEstimate: Int
    - sunlightThisTick: Int
    - beeBonusThisTickPct: Int
    - farm: Int
    - incidentOrderListThisTick: List<Incident>
    + killPlant(): Unit
    + pollinate(): Unit
    + reduceSoilMoisture(amount: Int): Unit
    + getNeededWaterToMaxMoisture(): Int
    + moistureBelowThreshold(): Boolean
    + decreaseSunlightPerCloudTraverse(): Unit
    + getMissedActions(): List<ActionType>
    + updateHarvestEstimate(currentYearTick: YearTick, currentTick: Int): Unit
    + setPlant(plant: Plant): Unit
    + isWorkedOnThisTick(currentTick: Int): Boolean
    - setInitialHarvestOnPlantationIfNovember(currentYearTick: YearTick) : Unit
    - resetHarvestAfterSowed() : Unit
    - applySowingLatePenalty() : Unit
    - applyEnvironmentalPenalty() : Unit
    - applyActionPenalty(): Unit
    - applyIncidentPenalty() : Unit
}

class Field {
    - plant: FieldPlant?
    - possiblePlants: List<PlantType>
    - sowTick: Int?
    - weedingDoneTicks: Set<Int>
    - fallowUntilTick: Int?
    +setPlant(plant: FieldPlant): Unit
    +canBeSowed(current_tick: Int, year_tick: YearTick): Boolean
    +isSowed(currentTick : int) : Boolean
}


Field -|> FarmableTile
class Plantation {
    - plant: PlantationPlant
    - cutThisCycle: Boolean
    - mowingDoneTicks: Set<Int>
    - harvestedThisTick: Boolean
    - operatedOnThisTick: Boolean
    - permanentDisabled: Boolean
    + setPlant(plant: PlantationPlant)
    - setInitialHarvestOnPlantationInNovember() : Unit
}
}

package Cloud #orange {
class Cloud {
    - id: Int
    - duration: Int
    - location: Int
    - amount: Int
    - availableMovesLeft = 10: Int
}

class CloudHandler {
    - tileManager: TileManager
    - clouds: List<Cloud>
    + run()
    + createCloud(location: Int, radius: Int, duration: Int, amount: Int)
    + removeCloud(cloud: Cloud): Unit
    - getHighestCloudId(): Int
    - decreaseCloudyTilesSunlight(): Unit
    - moveCloud(cloud: Cloud): Unit
    - isOnVillage(cloud: Cloud): Boolean
    - rain(cloud: Cloud): Unit
    - rainToFillTile(cloud: Cloud, amount: Int): Unit
    - rainToEmptyCloud(cloud: Cloud, amount: Int): Unit
    - checkCollision(cloud: Cloud): Cloud?
    - merge(cloud1: Cloud, cloud2: Cloud) : Unit
}
}


package Farm #yellow {
class Farm {
    - id: Int
    - name: String
    - farmsteads: List<Tile>
    - fields: List<Field>
    - plantations: List<Plantation>
    - machines: List<Machine>
    - machineToShed: Map<Machine, Farmstead>
    - totalHarvestByPlant: Map<PlantType, Int>
    - sowingPlans : List<SowingPlan>
    + run(currentTick: Int, currentYearTick: Int): Unit
    - executePlan(sp: SowingPlan)
    - sowFields(currentTick: Int, yearTick: Int)
    - harvestFields(currentTick: Int, yearTick: Int)
    - harvestPlantations(currentTick: Int, yearTick: YearTick): Unit
    - doRemainingActions(currentTick: Int, yearTick: YearTick): Unit
    - getFulfillableSowingPlans(currentTick: Int, yearTick: YearTick): List<SowingPlan>
    - getPlantationsWithHarvestablePlants(currentTick: Int, yearTick: YearTick): List<Plantation>
    - getFieldsWithHarvestablePlants(currentTick: Int, yearTick: YearTick): List<Field>
    - getFieldsWithIrrigatingPlants(tileType: PlantType): List<Field>
    - getAvailableHarvestingMachines(): List<Machine>
    - getAvailableSowingMachines(): List<Machine>
    - getAvailableMachines(): List<Machine>
}

class Machine {
    - tileManager: TileManager
    - id: Int
    - name: String
    - actions: List<ActionType>
    - designatedPlants: List<PlantType>
    - duration: Int
    - location: Tile
    - repairDuration: Int
    - isAvailable: Boolean
    - homeShed: Int
    - cargo: Map<PlantType, Int>
    - sowingDoneTick: Int?
    - handledThisTick: Int
    + performAction(action: ActionType): Unit
    ' doSowing function: updates the location of the machine, sets isAvailable to false,
    - doSowing(tile: Tile, currentTick: Int, yearTick: YearTick, plant: PlantType): Boolean
    - doHarvesting(tile: Tile, currentTick: Int, yearTick; YearTick): Boolean
    - doCutting(tile: Tile, currentTick: Int): Boolean
    - doMowing(tile: Tile, currentTick: Int): Boolean
    - doIrrigating(tile: Tile, currentTick: Int): Boolean
    - doWeeding(tile: Tile, currentTick: Int): Boolean
    - returnToFarmstead(farmstead: Tile): Boolean
    - canHandle(plantType: plantType, tile: FarmableTile): Boolean
    - restoreAvailability()
}

class SowingPlan {
    - id : Int
    - tick : Int
    - plantType : PlantType
    - fields : List<Field>?
    - location : Int?
    - radius : Int?
    - fulfilled: Boolean
}
}


package Incidents #lightblue {


abstract class Incident {
  # id: Int
  # tick: Int
  {abstract} + perform(): Unit
}

class CloudCreationIncident {
  - cloudHandler: CloudHandler
  - duration: Int
  - location: Int
  - radius: Int
  - amount: Int
  + perform(): Unit
}

class BeeHappyIncident {
  - tileManager: TileManager
  - location: Int
  - radius: Int
  - effect: Int
  + perform(): Unit
}

class DroughtIncident {
    - tileManager: TileManager
    - location: Int
    - radius: Int
    + perform(): Unit
}

class BrokenMachineIncident {
    - farms: List<Farm>
    - duration: Int
    - machineID: Int
    + perform(): Unit
}

class CityExpansionIncident {
    - farms: List<Farm>
    - tileManager: TileManager
    - location: Int
    + perform(): Unit
}

class AnimalAttackIncident {
    - tileManager: TileManager
    - location : Int
    - radius: Int

    +perform(): Unit
}
}

package Simulation #lightgreen {
class Main {
  - main(): Unit
}

class Simulation {
  - incidents: List<Incident>
  - farms: Map<Int,Farm>
  - cloudHandler: CloudHandler
  - tileManager: TileManager

  - currentTick: Int
  - currentYearTick: YearTick
  - maxTick: Int

  + run(): Unit
  - runTick(currentTick: Int, currentYearTick: YearTick): Unit
  - farmAction(currentTick: Int, currentYearTick: Int): Unit
  - handleClouds(): Unit
  - reduceSoilMoisture(): Unit
  - incidentStart(): Unit
  - computeHarvest(): Unit
}


class TileManager {
    - idToTile: Map<Int,Tile>
    - coordinateToTile: Map<Coordinate,Tile>
    + getTileById(id: Int): Tile?
    + getTileByCoords(coords: Coordinate): Tile?
    + getNeighborInDirection(tile: Tile): Tile?
    + getAllNeighborTilesInRadius(tile: Tile, radius: Int): List<Tile>
    + getFieldsAndPlantationsSameFarmInRadius(farmID: Int, tile:Tile, radius: Int): List<FarmableTile>
    + updateTile(newTile: Tile): Unit
    + shortestPathLength(start: Tile, target: Tile): Int?
    + existsPath(start:Tile, target: Tile, farmID: Int, hasHarvest: Boolean): Boolean
    + getFields(): List<Field>
    + getPlantations(): List<Plantation>
}

class Coordinate {
    - x: Int
    - y: Int
    + getNeighborCoordinateInDirection(direction: Direction): Coordinate
    + getAllNeighbors(): List<Coordinate>
    + equals(coordinate: Coordinate): Boolean
}

}
